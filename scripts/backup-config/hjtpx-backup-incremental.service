[Unit]
Description=HJTPX Incremental Database Backup
After=network.target postgresql.service

[Service]
Type=oneshot
User=postgres
WorkingDirectory=/workspace/hjtpx
ExecStart=/workspace/hjtpx/scripts/backup.sh incremental
StandardOutput=append:/workspace/hjtpx/logs/backup_incr.log
StandardError=append:/workspace/hjtpx/logs/backup_incr.log
Environment="BACKUP_DIR=/var/backups/hjtpx"

