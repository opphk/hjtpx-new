{
  "name": "@captchax/react",
  "version": "1.0.0",
  "description": "CaptchaX React Components - Modern captcha solution for React applications",
  "main": "dist/captchax-react.cjs.js",
  "module": "dist/captchax-react.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
