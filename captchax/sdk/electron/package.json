{
  "name": "captcha-electron",
  "version": "1.0.0",
  "description": "CaptchaX Electron SDK - 跨平台桌面验证码解决方案",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "example": "electron example/main.js"
  },
  "keywords": [
    "captcha",
    "electron",
    "slider-captcha",
    "click-captcha",
    "puzzle-captcha",
    "rotate-captcha",
    "text-captcha",
    "icon-captcha",
    "verification"
  ],
  "author": "CaptchaX Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.captchax.electron",
    "productName": "CaptchaX SDK Demo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
