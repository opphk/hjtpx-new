{
    "name": "captchax/sdk",
    "description": "CaptchaX Multi-language SDK - PHP client for CaptchaX verification service",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "CaptchaX\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CaptchaX\\SDK\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "ext-curl": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "suggest": {
        "guzzlehttp/guzzle": "For better HTTP performance",
        "symfony/http-client": "Alternative HTTP client"
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src --level=5",
        "cs": "phpcs --standard=PSR12 src"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "captcha",
        "verification",
        "slider",
        "click",
        "puzzle",
        "security"
    ],
    "authors": [
        {
            "name": "CaptchaX Team",
            "email": "team@captchax.dev"
        }
    ]
}
