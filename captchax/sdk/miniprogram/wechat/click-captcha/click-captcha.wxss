.click-captcha-container {
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #fff;
  border-radius: 12rpx;
}

.instruction {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20rpx;
}

.captcha-image-wrapper {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  background: #f5f5f5;
}

.captcha-background {
  width: 100%;
  height: 100%;
}

.click-point {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  background: rgba(74, 144, 226, 0.8);
  border: 3rpx solid #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  animation: pointAppear 0.3s ease-out;
}

.point-number {
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
}

@keyframes pointAppear {
  from {
    transform: translate(-50%, -50%) scale(0);
  }
  to {
    transform: translate(-50%, -50%) scale(1);
  }
}

.click-info {
  text-align: center;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.click-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.action-btn {
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: none;
}

.undo-btn {
  background: #fff;
  color: #666;
  border: 1rpx solid #ddd;
}

.reset-btn {
  background: #4a90e2;
  color: #fff;
}

.action-btn[disabled] {
  opacity: 0.5;
}
