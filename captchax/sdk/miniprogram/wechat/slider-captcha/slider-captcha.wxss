.slider-captcha-container {
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #fff;
  border-radius: 12rpx;
}

.captcha-image-wrapper {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.captcha-background {
  width: 100%;
  height: 100%;
}

.slider-block {
  position: absolute;
  top: 0;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  border-radius: 4rpx;
}

.slider-image {
  width: 100%;
  height: 100%;
}

.slider-track {
  padding: 0 10rpx;
}

.slider-hint {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
  text-align: center;
}

.slider-bar {
  position: relative;
  height: 80rpx;
  background: #f0f0f0;
  border-radius: 40rpx;
  overflow: hidden;
}

.slider-bar.dragging {
  background: #e8f4ff;
}

.slider-thumb {
  position: absolute;
  top: 5rpx;
  width: 70rpx;
  height: 70rpx;
  background: linear-gradient(135deg, #4a90e2, #357abd);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 10rpx rgba(74, 144, 226, 0.4);
  cursor: pointer;
  transition: transform 0.1s;
}

.slider-thumb:active {
  transform: scale(0.95);
}

.slider-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}
