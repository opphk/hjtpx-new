.puzzle-captcha-container {
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #fff;
  border-radius: 12rpx;
}

.captcha-wrapper {
  margin-bottom: 20rpx;
}

.captcha-image-area {
  position: relative;
  width: 100%;
  height: 400rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}

.background-image {
  width: 100%;
  height: 100%;
}

.puzzle-slot {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.2);
  border: 2rpx dashed #999;
  border-radius: 4rpx;
  z-index: 1;
}

.puzzle-piece {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  z-index: 2;
  cursor: move;
  transition: box-shadow 0.2s;
}

.puzzle-piece.dragging {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.4);
}

.puzzle-piece.success {
  box-shadow: 0 0 0 3rpx #4CAF50;
  background: rgba(76, 175, 80, 0.3);
}

.puzzle-image {
  width: 100%;
  height: 100%;
}

.puzzle-instruction {
  text-align: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.puzzle-actions {
  display: flex;
  justify-content: center;
}

.refresh-btn {
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  background: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 8rpx;
}

.refresh-btn:active {
  background: #e0e0e0;
}
