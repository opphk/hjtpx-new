.text-captcha-container {
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  background-color: #fff;
  border-radius: 12rpx;
}

.question-section {
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  text-align: center;
  display: block;
}

.image-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}

.captcha-image {
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.refresh-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

.options-section {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
  cursor: pointer;
  transition: all 0.2s;
}

.option-item.selected {
  background: #e3f2fd;
  border-color: #2196f3;
}

.option-item.correct {
  background: #e8f5e9;
  border-color: #4caf50;
}

.option-item.wrong {
  background: #ffebee;
  border-color: #f44336;
}

.option-marker {
  width: 40rpx;
  height: 40rpx;
  background: #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 15rpx;
}

.option-item.selected .option-marker {
  background: #2196f3;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.option-result {
  font-size: 32rpx;
  font-weight: bold;
}

.option-item.correct .option-result {
  color: #4caf50;
}

.option-item.wrong .option-result {
  color: #f44336;
}

.action-section {
  display: flex;
  justify-content: center;
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 30rpx;
  background: #ddd;
  color: #fff;
  border: none;
  border-radius: 8rpx;
}

.submit-btn.active {
  background: #4a90e2;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
