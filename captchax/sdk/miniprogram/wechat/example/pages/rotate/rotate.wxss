.rotate-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.page-header {
  text-align: center;
  padding: 40rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.page-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.captcha-wrapper {
  margin-bottom: 30rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  background: #fff;
  border-radius: 12rpx;
}

.captcha-container {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.action-buttons {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.refresh-btn {
  padding: 20rpx 60rpx;
  background: #4a90e2;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.result-panel {
  text-align: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 12rpx;
}

.result-text {
  font-size: 32rpx;
  font-weight: bold;
}

.result-text.success {
  color: #4caf50;
}

.result-text.fail {
  color: #f44336;
}
