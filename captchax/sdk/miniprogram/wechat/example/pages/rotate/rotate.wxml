<view class="rotate-page">
  <view class="page-header">
    <text class="page-title">旋转验证码</text>
    <text class="page-desc">旋转图片到正确角度</text>
  </view>

  <view class="captcha-wrapper">
    <view wx:if="{{isLoading}}" class="loading">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{captchaData}}" class="captcha-container">
      <rotate-captcha
        captchaId="{{captchaData.captchaId}}"
        imageUrl="{{captchaData.imageUrl}}"
        targetAngle="{{captchaData.targetAngle}}"
        imageSize="{{captchaData.imageSize || {width: 200, height: 200}}}"
        bindverify="onVerify"
      />
    </view>
  </view>

  <view class="action-buttons">
    <button class="refresh-btn" bindtap="onRefresh">
      刷新验证码
    </button>
  </view>

  <view class="result-panel" wx:if="{{isVerified}}">
    <text class="result-text {{verifyResult ? 'success' : 'fail'}}">
      {{verifyResult ? '✓ 验证成功' : '✗ 验证失败'}}
    </text>
  </view>
</view>
