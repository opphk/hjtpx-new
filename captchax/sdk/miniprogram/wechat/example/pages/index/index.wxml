<view class="container">
  <view class="header">
    <text class="title">CaptchaX 示例</text>
    <text class="subtitle">微信小程序验证码集成示例</text>
  </view>

  <view class="captcha-list">
    <view class="captcha-item" bindtap="navigateTo" data-page="slider">
      <view class="captcha-icon">▭</view>
      <view class="captcha-info">
        <text class="captcha-name">滑块验证码</text>
        <text class="captcha-desc">拖动滑块完成验证</text>
      </view>
      <text class="arrow">→</text>
    </view>

    <view class="captcha-item" bindtap="navigateTo" data-page="click">
      <view class="captcha-icon">⊙</view>
      <view class="captcha-info">
        <text class="captcha-name">点选验证码</text>
        <text class="captcha-desc">点击指定位置完成验证</text>
      </view>
      <text class="arrow">→</text>
    </view>

    <view class="captcha-item" bindtap="navigateTo" data-page="puzzle">
      <view class="captcha-icon">🧩</view>
      <view class="captcha-info">
        <text class="captcha-name">拼图验证码</text>
        <text class="captcha-desc">移动拼图块到正确位置</text>
      </view>
      <text class="arrow">→</text>
    </view>

    <view class="captcha-item" bindtap="navigateTo" data-page="rotate">
      <view class="captcha-icon">↻</view>
      <view class="captcha-info">
        <text class="captcha-name">旋转验证码</text>
        <text class="captcha-desc">旋转图片到正确角度</text>
      </view>
      <text class="arrow">→</text>
    </view>

    <view class="captcha-item" bindtap="navigateTo" data-page="text">
      <view class="captcha-icon">文</view>
      <view class="captcha-info">
        <text class="captcha-name">文字验证码</text>
        <text class="captcha-desc">选择正确的文字答案</text>
      </view>
      <text class="arrow">→</text>
    </view>

    <view class="captcha-item" bindtap="navigateTo" data-page="icon">
      <view class="captcha-icon">★</view>
      <view class="captcha-info">
        <text class="captcha-name">图标验证码</text>
        <text class="captcha-desc">选择正确的图标</text>
      </view>
      <text class="arrow">→</text>
    </view>
  </view>

  <view class="footer">
    <text>Cloaded with CaptchaX SDK</text>
  </view>
</view>
