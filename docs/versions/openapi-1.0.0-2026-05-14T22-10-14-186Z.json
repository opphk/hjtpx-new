                      "csv",
                      "excel",
                      "json",
                      "pdf"
                    ],
                    "default": "csv"
                  },
                  "filename": {
                    "type": "string",
                    "default": "export"
                  },
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
